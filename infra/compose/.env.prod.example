COMPOSE_PROJECT_NAME=nta-platform
APP_IMAGE_TAG=latest
APP_ENV=production
APP_NAME=nta-platform
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

HTTP_PORT=80
TEMPORAL_UI_PORT=8088
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001

NGINX_VERSION=1.27-alpine
POSTGRESQL_IMAGE=pgvector/pgvector:pg16
REDIS_VERSION=7-alpine
TEMPORAL_VERSION=1.29.4
TEMPORAL_ADMINTOOLS_VERSION=1.29.4
TEMPORAL_UI_VERSION=latest
RUSTFS_VERSION=latest
MINIO_MC_VERSION=latest

POSTGRES_USER=nta
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=nta_platform

SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["https://nta.example.com"]

DATABASE_URL=postgresql+asyncpg://nta:replace-with-strong-password@postgres:5432/nta_platform
REDIS_URL=redis://redis:6379/0

TEMPORAL_NAMESPACE=nta-platform
TEMPORAL_HOST=temporal:7233
TEMPORAL_TASK_QUEUE_EVAL=eval-jobs
TEMPORAL_TASK_QUEUE_BATCH=batch-jobs
TEMPORAL_TASK_QUEUE_DATASET=dataset-import

S3_ENDPOINT_URL=http://rustfs:9000
S3_BROWSER_ENDPOINT_URL=https://objects.nta.example.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET_MAIN=nta-default
S3_LOCAL_FALLBACK_ENABLED=false
S3_CORS_ALLOWED_ORIGINS=https://nta.example.com

API_BASE_URL=http://api:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SSE_BASE_URL=
NEXT_PUBLIC_WS_BASE_URL=

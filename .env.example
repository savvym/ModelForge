# Shared
APP_ENV=development
APP_NAME=nta-platform
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Frontend
API_BASE_URL=http://127.0.0.1:8081/api/v1
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8081/api/v1
NEXT_PUBLIC_SSE_BASE_URL=http://127.0.0.1:8081/api/v1/streams
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8081/ws

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_PATH=/api/v1
SECRET_KEY=replace-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL
POSTGRES_USER=nta
POSTGRES_PASSWORD=nta
POSTGRES_DB=nta_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nta:nta@localhost:5432/nta_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=nta-platform-dev
TEMPORAL_TASK_QUEUE_EVAL=eval-jobs
TEMPORAL_TASK_QUEUE_BATCH=batch-jobs
TEMPORAL_TASK_QUEUE_DATASET=dataset-import

# Object Storage
S3_ENDPOINT_URL=http://127.0.0.1:8081
S3_BROWSER_ENDPOINT_URL=http://127.0.0.1:8081
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=ChangeMe123!
S3_BUCKET_MAIN=nta-default
